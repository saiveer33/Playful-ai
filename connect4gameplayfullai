# Constants
ROWS = 6
COLS = 7
SQUARESIZE = 100
RADIUS = SQUARESIZE // 2 - 5
WIDTH = COLS * SQUARESIZE
HEIGHT = (ROWS + 2) * SQUARESIZE
WHITE = (255, 255, 255)
BLUE = (0, 0, 255)
RED = (255, 0, 0)
YELLOW = (255, 255, 0)
BLACK = (0, 0, 0)
GRAY = (169, 169, 169)

PLAYER = 1
AI = 2
DEPTH = 4
EMPTY = 0

py.init()
size = (WIDTH, HEIGHT)
screen = py.display.set_mode(size)
font = py.font.SysFont("monospace", 40)
py.display.set_caption("Connect 4 - Player vs AI")

BUTTON_WIDTH = 180
BUTTON_HEIGHT = 50
START_BTN = py.Rect(10, 10, BUTTON_WIDTH, BUTTON_HEIGHT)
RESTART_BTN = py.Rect(200, 10, BUTTON_WIDTH, BUTTON_HEIGHT)
QUIT_BTN = py.Rect(WIDTH - BUTTON_WIDTH - 10, 10, BUTTON_WIDTH, BUTTON_HEIGHT)


def create_board():
    return np.zeros((ROWS, COLS), dtype=int)


def draw_buttons():
    py.draw.rect(screen, GRAY, START_BTN)
    py.draw.rect(screen, GRAY, RESTART_BTN)
    py.draw.rect(screen, GRAY, QUIT_BTN)

    start_text = font.render("Start", True, BLACK)
    restart_text = font.render("Restart", True, BLACK)
    quit_text = font.render("Quit", True, BLACK)

    screen.blit(start_text, (START_BTN.x + 25, START_BTN.y + 10))
    screen.blit(restart_text, (RESTART_BTN.x + 10, RESTART_BTN.y + 10))
    screen.blit(quit_text, (QUIT_BTN.x + 40, QUIT_BTN.y + 10))


def draw_board(board):
    screen.fill(BLACK)
    draw_buttons()

    for c in range(COLS):
        for r in range(ROWS):
            py.draw.rect(screen, BLUE, (c * SQUARESIZE, (r + 2) * SQUARESIZE, SQUARESIZE, SQUARESIZE))
            py.draw.circle(screen, WHITE, (c * SQUARESIZE + SQUARESIZE // 2, (r + 2) * SQUARESIZE + SQUARESIZE // 2),
                           RADIUS)

    for c in range(COLS):
        for r in range(ROWS):
            if board[r][c] == PLAYER:
                py.draw.circle(screen, YELLOW, (c * SQUARESIZE + SQUARESIZE // 2,
                                                  HEIGHT - (r + 1) * SQUARESIZE + SQUARESIZE // 2), RADIUS)
            elif board[r][c] == AI:
                py.draw.circle(screen, RED, (c * SQUARESIZE + SQUARESIZE // 2,
                                               HEIGHT - (r + 1) * SQUARESIZE + SQUARESIZE // 2), RADIUS)

    py.display.update()


def is_valid_location(board, col):
    return board[ROWS - 1][col] == 0


def get_valid_columns(board):
    return [c for c in range(COLS) if is_valid_location(board, c)]


def drop_piece(board, col, piece):
    for r in range(ROWS):
        if board[r][col] == 0:
            board[r][col] = piece
            return r


def check_win(board, piece):
    for r in range(ROWS):
        for c in range(COLS - 3):
            if all(board[r][c + i] == piece for i in range(4)):
                return True

    for r in range(ROWS - 3):
        for c in range(COLS):
            if all(board[r + i][c] == piece for i in range(4)):
                return True

    for r in range(3, ROWS):
        for c in range(COLS - 3):
            if all(board[r - i][c + i] == piece for i in range(4)):
                return True

    for r in range(ROWS - 3):
        for c in range(COLS - 3):
            if all(board[r + i][c + i] == piece for i in range(4)):
                return True

    return False


def display_winner(winner):
    text = font.render(f"{winner} Wins!", True, (255, 255, 255))
    text_rect = text.get_rect(center=(370, 130))
    screen.blit(text, text_rect)
