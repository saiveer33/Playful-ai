def board_to_string(board):
    """Converts the board to a string representation."""
    board_str = ""
    for row in reversed(board):  # Print from top row down
        board_str += str(list(row)) + "\n"
    return board_str

def generate_openai_prompt(board, valid_columns):
    """Generates a prompt for OpenAI's GPT model."""
    board_str = board_to_string(board)

    prompt = f"""You are an expert Connect 4 player.  The game is represented as follows:
{board_str}
0 represents empty, 1 represents Player, 2 represents AI.

It is the AI's turn to play.

Valid moves (columns to play in, numbered from 0) are: {valid_columns}

You are playing as the AI (2). Which column would you pick? Answer with a single integer. briefly explain your reasoning.
"""
    return prompt

def get_openai_move(board, valid_columns, model="gpt-3.5-turbo"):
    """Calls OpenAI to get the AI's move."""
    prompt = generate_openai_prompt(board, valid_columns)

    try:
        response = openai.chat.completions.create(
            model=model,
            messages=[{"role": "user", "content": prompt}],
            max_tokens=10,  # Limit response length
            n=1,  # Number of responses
            stop=None,  # Stop sequence
            temperature=0.7,  # Adjust for creativity vs. predictability
        )

        move_str = response.choices[0].message.content.strip()
        print(f"OpenAI Response: {move_str}")

        # Extract column number from the response (handle errors)
        try:
            parts = move_str.split()
            for part in parts:
                try:
                    move = int(part)
                    if move in valid_columns:  # VERY IMPORTANT, validate move
                        return move
                except ValueError:
                    pass  # Not a number

            print("Could not reliably extract move from OpenAI response.  Returning random valid move.")
            return rd.choice(valid_columns)
        except Exception as e:
            print(f"Error parsing OpenAI response: {e}. Returning random valid move.")
            return rd.choice(valid_columns)

    except Exception as e:
        print(f"Error calling OpenAI: {e}.  Returning random valid move.")
        return rd.choice(valid_columns)



def minimax(board, depth, alpha, beta, maximizing, use_openai=False):
    
    valid_columns = get_valid_columns(board)

    if depth == 0 or len(valid_columns) == 0 or check_win(board, PLAYER) or check_win(board, AI):
        if check_win(board, AI):
            return None, 1000000
        elif check_win(board, PLAYER):
            return None, -1000000
        else:
            return None, 0

    if maximizing:
        value = -mt.inf
        best_col = rd.choice(valid_columns)
        for col in valid_columns:
            temp_board = board.copy()
            row = drop_piece(temp_board, col, AI)
            new_score = minimax(temp_board, depth-1, alpha, beta, False, use_openai)[1]
            if new_score > value:
                value = new_score
                best_col = col
            
            temp_board[row][col] = 0 #undo move
            alpha = max(alpha, value)
            if alpha >= beta:
                break
        return best_col, value
    else:
        value = mt.inf
        best_col = rd.choice(valid_columns)
        for col in valid_columns:
            temp_board = board.copy()
            row = drop_piece(temp_board, col, PLAYER)
            new_score = minimax(temp_board, depth-1, alpha, beta, True, use_openai)[1]
            if new_score < value:
                value = new_score
                best_col = col

            temp_board[row][col] = 0 #undo move
            beta = min(beta, value)
            if alpha >= beta:
                break
        return best_col, value

def main():
    board = create_board()
    game_over = False
    turn = 0
    running = False  
    use_openai = True

    draw_board(board)
    while True:
        for event in py.event.get():
            if event.type == py.QUIT:
                sys.exit()
            display_player()

            if event.type == py.MOUSEBUTTONDOWN:
                x, y = event.pos
            
                if START_BTN.collidepoint(x, y):
                    running = True
                    board = create_board()
                    game_over = False
                    turn = 0
                    draw_board(board)

                if RESTART_BTN.collidepoint(x, y) and running:
                    board = create_board()
                    game_over = False
                    turn = 0
                    draw_board(board)

                if QUIT_BTN.collidepoint(x, y):
                    sys.exit()
               
                if running and not game_over:
                    if turn % 2 == 0 and y > SQUARESIZE * 2: #Player's turn
                        col = x // SQUARESIZE
                        if is_valid_location(board, col):
                            drop_piece(board, col, PLAYER)
                            draw_board(board)
                            if check_win(board, PLAYER):
                                display_winner("Player")
                                game_over = True
                            turn += 1


                    elif turn % 2 != 0 and not game_over:
                        valid_columns = get_valid_columns(board)
                        if use_openai and rd.random() < 0.2:
                            col = get_openai_move(board, valid_columns)
                        else:
                            col, _ = minimax(board, DEPTH, -mt.inf, mt.inf, True, use_openai)
                        if is_valid_location(board, col):
                            drop_piece(board, col, AI)
                            draw_board(board)
                            if check_win(board, AI):
                                display_winner("AI")
                                game_over = True
                            turn += 1


if __name__ == "__main__":
    main()